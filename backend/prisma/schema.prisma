generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETION_PENDING
}

enum UnitSystem {
  METRIC
  IMPERIAL
}

enum BodyType {
  RECTANGLE
  TRIANGLE
  INVERTED_TRIANGLE
  OVAL
  HOURGLASS
}

enum StylePreference {
  MINIMALIST
  CLASSIC
  NORDIC
  WORKWEAR
  SPORT
  TAILORED
  STREETWEAR
}

enum Occasion {
  WORK
  CASUAL
  EVENING
  TRAVEL
  FORMAL
  SPORT
}

enum ShoppingFrequency {
  RARELY
  FEW_TIMES_YEAR
  SEASONALLY
  MONTHLY
}

enum PriceSensitivity {
  BUDGET
  BALANCED
  PREMIUM
  INVESTMENT_ONLY
}

enum WardrobeGoal {
  REDUCE_DECISIONS
  BUILD_CAPSULE_WARDROBE
  PLAN_OUTFITS
  SHOP_SMARTER
  TRACK_USAGE
}

enum CapsuleStatus {
  STARTING
  TRANSITIONING
  MOSTLY_CAPSULE
  FULLY_CAPSULE
}

enum WardrobeCategory {
  TOP
  BOTTOM
  OUTERWEAR
  SHOES
  ACCESSORY
}

enum AvailabilityStatus {
  AVAILABLE
  LAUNDRY
  UNAVAILABLE
}

enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
}

enum WaterResistance {
  NONE
  WATER_RESISTANT
  WATERPROOF
}

enum ColorRole {
  PRIMARY
  SECONDARY
  ACCENT
}

enum OutfitStatus {
  DRAFT
  SAVED
  ARCHIVED
}

enum OutfitSlot {
  TOP
  BOTTOM
  SHOES
  OUTERWEAR
  ACCESSORY
}

enum WearSource {
  DASHBOARD
  CALENDAR
  OUTFIT_PAGE
  MANUAL
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.VarChar(320)
  passwordHash    String     @map("password_hash") @db.VarChar(255)
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz(3)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  profile         UserProfile?
  sessions        AuthSession[]
  wardrobeItems   WardrobeItem[]
  outfits         Outfit[]
  calendarEntries CalendarEntry[]
  wearEvents      WearEvent[]
  tags            Tag[]
  favoriteColors  UserFavoriteColor[]

  @@map("users")
}

model UserProfile {
  userId            String             @id @map("user_id") @db.Uuid
  firstName         String?            @map("first_name") @db.VarChar(80)
  lastName          String?            @map("last_name") @db.VarChar(80)
  dateOfBirth       DateTime?          @map("date_of_birth") @db.Date
  countryCode       String?            @map("country_code") @db.Char(2)
  city              String?            @db.VarChar(120)
  timeZone          String             @default("UTC") @map("time_zone") @db.VarChar(64)
  unitSystem        UnitSystem         @default(METRIC) @map("unit_system")
  heightCm          Int?               @map("height_cm") @db.SmallInt
  weightKg          Decimal?           @map("weight_kg") @db.Decimal(5, 2)
  bodyType          BodyType?          @map("body_type")
  preferredStyles   StylePreference[]  @default([]) @map("preferred_styles")
  typicalOccasions  Occasion[]         @default([]) @map("typical_occasions")
  shoppingFrequency ShoppingFrequency? @map("shopping_frequency")
  priceSensitivity  PriceSensitivity?  @map("price_sensitivity")
  goals             WardrobeGoal[]     @default([])
  capsuleStatus     CapsuleStatus?     @map("capsule_status")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model AuthSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(3)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(3)
  userAgent  String?   @map("user_agent") @db.VarChar(512)
  ipAddress  String?   @map("ip_address") @db.Inet
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model Color {
  id        String @id @default(uuid()) @db.Uuid
  name      String @db.VarChar(60)
  slug      String @unique @db.VarChar(60)
  hex       String @db.Char(7)
  sortOrder Int    @default(0) @map("sort_order") @db.SmallInt

  itemColors WardrobeItemColor[]
  favoriteBy UserFavoriteColor[]

  @@map("colors")
}

model UserFavoriteColor {
  userId  String @map("user_id") @db.Uuid
  colorId String @map("color_id") @db.Uuid

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  color Color @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@id([userId, colorId])
  @@index([colorId])
  @@map("user_favorite_colors")
}

model Material {
  id   String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(80)
  slug String @unique @db.VarChar(80)

  itemMaterials WardrobeItemMaterial[]

  @@map("materials")
}

model WardrobeItem {
  id                      String             @id @default(uuid()) @db.Uuid
  userId                  String             @map("user_id") @db.Uuid
  name                    String             @db.VarChar(120)
  description             String?            @db.Text
  category                WardrobeCategory
  subcategory             String?            @db.VarChar(80)
  brand                   String?            @db.VarChar(100)
  size                    String?            @db.VarChar(40)
  availability            AvailabilityStatus @default(AVAILABLE)
  availabilityChangedAt   DateTime           @default(now()) @map("availability_changed_at") @db.Timestamptz(3)
  availableFrom           DateTime?          @map("available_from") @db.Timestamptz(3)
  unavailableReason       String?            @map("unavailable_reason") @db.VarChar(160)
  isFavorite              Boolean            @default(false) @map("is_favorite")
  seasons                 Season[]           @default([])
  occasions               Occasion[]         @default([])
  warmthLevel             Int?               @map("warmth_level") @db.SmallInt
  waterResistance         WaterResistance    @default(NONE) @map("water_resistance")
  isWindResistant         Boolean            @default(false) @map("is_wind_resistant")
  purchaseDate            DateTime?          @map("purchase_date") @db.Date
  purchasePrice           Decimal?           @map("purchase_price") @db.Decimal(12, 2)
  currencyCode            String?            @map("currency_code") @db.Char(3)
  wearCountBeforeTracking Int                @default(0) @map("wear_count_before_tracking")
  lastWornBeforeTracking  DateTime?          @map("last_worn_before_tracking") @db.Timestamptz(3)
  archivedAt              DateTime?          @map("archived_at") @db.Timestamptz(3)
  createdAt               DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  images         WardrobeItemImage[]
  colors         WardrobeItemColor[]
  materials      WardrobeItemMaterial[]
  outfitLinks    OutfitItem[]
  wearEventItems WearEventItem[]

  @@index([userId, archivedAt])
  @@index([userId, category, archivedAt])
  @@index([userId, availability, archivedAt])
  @@index([userId, isFavorite, archivedAt])
  @@map("wardrobe_items")
}

model WardrobeItemImage {
  id                 String   @id @default(uuid()) @db.Uuid
  wardrobeItemId     String   @map("wardrobe_item_id") @db.Uuid
  cloudinaryPublicId String   @unique @map("cloudinary_public_id") @db.VarChar(255)
  secureUrl          String   @map("secure_url") @db.Text
  version            Int?
  format             String?  @db.VarChar(20)
  width              Int?
  height             Int?
  altText            String?  @map("alt_text") @db.VarChar(160)
  position           Int      @default(0) @db.SmallInt
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  @@unique([wardrobeItemId, position])
  @@map("wardrobe_item_images")
}

model WardrobeItemColor {
  wardrobeItemId String    @map("wardrobe_item_id") @db.Uuid
  colorId        String    @map("color_id") @db.Uuid
  role           ColorRole @default(PRIMARY)
  position       Int       @default(0) @db.SmallInt

  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)
  color        Color        @relation(fields: [colorId], references: [id], onDelete: Restrict)

  @@id([wardrobeItemId, colorId])
  @@unique([wardrobeItemId, role, position])
  @@index([colorId, wardrobeItemId])
  @@map("wardrobe_item_colors")
}

model WardrobeItemMaterial {
  wardrobeItemId String @map("wardrobe_item_id") @db.Uuid
  materialId     String @map("material_id") @db.Uuid
  percentage     Int?   @db.SmallInt

  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)
  material     Material     @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@id([wardrobeItemId, materialId])
  @@index([materialId])
  @@map("wardrobe_item_materials")
}

model Outfit {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  name           String?      @db.VarChar(120)
  description    String?      @db.Text
  status         OutfitStatus @default(DRAFT)
  isFavorite     Boolean      @default(false) @map("is_favorite")
  occasions      Occasion[]   @default([])
  seasons        Season[]     @default([])
  warmthOverride Int?         @map("warmth_override") @db.SmallInt
  archivedAt     DateTime?    @map("archived_at") @db.Timestamptz(3)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OutfitItem[]
  tags            OutfitTag[]
  calendarEntries CalendarEntry[]
  wearEvents      WearEvent[]

  @@index([userId, status, archivedAt])
  @@index([userId, isFavorite, archivedAt])
  @@map("outfits")
}

model OutfitItem {
  id             String     @id @default(uuid()) @db.Uuid
  outfitId       String     @map("outfit_id") @db.Uuid
  wardrobeItemId String     @map("wardrobe_item_id") @db.Uuid
  slot           OutfitSlot
  layerOrder     Int        @default(0) @map("layer_order") @db.SmallInt
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)

  outfit       Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: NoAction)

  @@unique([outfitId, wardrobeItemId])
  @@unique([outfitId, slot, layerOrder])
  @@index([wardrobeItemId])
  @@map("outfit_items")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(60)
  slug      String   @db.VarChar(60)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfits OutfitTag[]

  @@unique([userId, slug])
  @@map("tags")
}

model OutfitTag {
  outfitId String @map("outfit_id") @db.Uuid
  tagId    String @map("tag_id") @db.Uuid

  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([outfitId, tagId])
  @@index([tagId])
  @@map("outfit_tags")
}

model CalendarEntry {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  outfitId     String   @map("outfit_id") @db.Uuid
  plannedDate  DateTime @map("planned_date") @db.Date
  contextLabel String?  @map("context_label") @db.VarChar(120)
  note         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit    Outfit     @relation(fields: [outfitId], references: [id], onDelete: NoAction)
  wearEvent WearEvent?

  @@unique([userId, plannedDate])
  @@index([outfitId, plannedDate])
  @@map("calendar_entries")
}

model WearEvent {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  outfitId        String?    @map("outfit_id") @db.Uuid
  calendarEntryId String?    @unique @map("calendar_entry_id") @db.Uuid
  wornAt          DateTime   @map("worn_at") @db.Timestamptz(3)
  source          WearSource
  note            String?    @db.Text
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit        Outfit?         @relation(fields: [outfitId], references: [id], onDelete: SetNull)
  calendarEntry CalendarEntry?  @relation(fields: [calendarEntryId], references: [id], onDelete: SetNull)
  items         WearEventItem[]

  @@index([userId, wornAt])
  @@index([outfitId, wornAt])
  @@map("wear_events")
}

model WearEventItem {
  wearEventId        String           @map("wear_event_id") @db.Uuid
  wardrobeItemId     String           @map("wardrobe_item_id") @db.Uuid
  slotSnapshot       OutfitSlot       @map("slot_snapshot")
  layerOrderSnapshot Int              @default(0) @map("layer_order_snapshot") @db.SmallInt
  itemNameSnapshot   String           @map("item_name_snapshot") @db.VarChar(120)
  categorySnapshot   WardrobeCategory @map("category_snapshot")

  wearEvent    WearEvent    @relation(fields: [wearEventId], references: [id], onDelete: Cascade)
  wardrobeItem WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: NoAction)

  @@id([wearEventId, wardrobeItemId])
  @@index([wardrobeItemId, wearEventId])
  @@map("wear_event_items")
}
